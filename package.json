{
  "name": "@geoblocks/edittrack",
  "version": "1.3.33",
  "description": "Geoblocks edittrack",
  "scripts": {
    "eslint": "eslint src test demos",
    "start": "vite",
    "build-demo": "vite build",
    "prepare": "tsc --pretty",
    "test": "mocha --exit",
    "typecheck": "tsc --pretty --noEmit",
    "lint": "npm run eslint && npm run typecheck",
    "doc": "typedoc",
    "gh-pages": "rm -rf dist && npm run doc && npm run build-demo && gh-pages -d dist"
  },
  "license": "BSD-3-Clause",
  "repository": "github:geoblocks/edittrack",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "lib",
    "CHANGES.md"
  ],
  "type": "module",
  "module": "lib/index.js",
  "types": "lib/types/index.d.ts",
  "devDependencies": {
    "@geoblocks/elevation-profile": "0.0.28",
    "@geoblocks/proj": "0.4.10",
    "@geoblocks/sources": "0.3.4",
    "@types/chai": "5.2.3",
    "@types/mocha": "10.0.10",
    "@typescript-eslint/eslint-plugin": "8.58.2",
    "@typescript-eslint/parser": "8.58.2",
    "chai": "6.2.2",
    "eslint": "10.2.1",
    "gh-pages": "6.3.0",
    "mocha": "11.7.5",
    "ol": "10.9.0",
    "ts-node": "10.9.2",
    "typedoc": "0.28.19",
    "typescript": "6.0.3",
    "vite": "8.0.9"
  },
  "peerDependencies": {
    "ol": "^6 || ^7 || ^8 || ^9 || ^10"
  }
}
